# Flutter / Dart
flutter_app/.dart_tool/
flutter_app/build/
flutter_app/.flutter-plugins
flutter_app/.flutter-plugins-dependencies
flutter_app/.metadata
flutter_app/.pub-cache/
flutter_app/.idea/
flutter_app/android/.gradle/
flutter_app/android/app/debug.keystore

# iOS
flutter_app/ios/Pods/
flutter_app/ios/.symlinks/
flutter_app/ios/Flutter/App.framework/
flutter_app/ios/Flutter/Flutter.framework/

# Web
flutter_app/web/**/*.dart.js
flutter_app/web/**/*.js.map

# Docker
.docker/
docker-compose.override.yml

# Environnement
.env
.env.local
*.env

# Logs & cache
*.log
*.sqlite
*.db

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# Divers
pubspec.lock

# AI
PROJECT_CONTEXT.md