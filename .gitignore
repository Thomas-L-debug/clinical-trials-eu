# ===============================================
# .gitignore - Clinical Trials EU
# ===============================================

# Flutter
flutter_app/.dart_tool/
flutter_app/build/
flutter_app/.pub-cache/
flutter_app/.flutter-plugins
flutter_app/.flutter-plugins-dependencies
flutter_app/.metadata
flutter_app/android/.gradle/
flutter_app/android/app/debug.keystore

# iOS
flutter_app/ios/Pods/
flutter_app/ios/.symlinks/
flutter_app/ios/Flutter/

# Web
flutter_app/web/**/*.dart.js
flutter_app/web/**/*.js.map

# Backend Dart
backend/.dart_tool/
backend/.pub-cache/
backend/build/

# Données temporaires
data/*.json
!data/ctis_trials_page1.json   # On garde le dernier dump pour référence

# Environnement & secrets
.env
.env.local
*.env

# Docker
docker-compose.override.yml

# Cache & Logs
*.log
*.sqlite
*.db
*.tmp

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# Pubspec lock files
pubspec.lock
**/pubspec.lock

# Mais on veut committer ceux-ci :
!backend/pubspec.lock
!flutter_app/pubspec.lock